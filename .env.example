# PokePrices — environment variable names
# ----------------------------------------
# Names and explanatory comments only. NEVER commit real values.
#
# Scopes
#   * NEXT_PUBLIC_* vars are inlined into the browser bundle at build
#     time. Treat their values as effectively public.
#   * Everything else is server-only. Never read on the client.
#
# Required vs optional
#   * Required vars (marked [REQUIRED]) must be set in Production AND in
#     any Preview environment you expect to use. Missing them in Production
#     produces 500s on routes that depend on them.
#   * Optional vars have a sensible documented fallback in src/lib/env.ts.

# ── Public ──────────────────────────────────────────────────────────────────

# [REQUIRED] Supabase REST + Auth + Storage base URL.
NEXT_PUBLIC_SUPABASE_URL=

# [REQUIRED] Supabase anon JWT for public reads and Auth flows.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# [optional] eBay Partner Network campaign IDs, one per marketplace.
# UK + US ship implemented + configured today.
#
# Important: NEXT_PUBLIC_* values are inlined into the browser bundle
# at BUILD TIME. Setting one in Vercel without triggering a new
# deployment changes nothing on the live site. Populating one of the
# additional CA/AU/DE/FR/IT/ES vars also does NOT activate that
# marketplace by itself — the URL engine in src/lib/ebayAffiliate.ts
# must also be extended and IMPLEMENTED_MARKETPLACES updated.
# Until both sides are true, the marketplace stays hidden from the
# selector and the settings dropdown.
# Missing → affiliate links for that marketplace render with empty
# campid (commission attribution lost) or the marketplace is hidden in
# the selector if it has no campid at all.
NEXT_PUBLIC_EBAY_CAMPID_UK=
NEXT_PUBLIC_EBAY_CAMPID_US=
NEXT_PUBLIC_EBAY_CAMPID_CA=
NEXT_PUBLIC_EBAY_CAMPID_AU=
NEXT_PUBLIC_EBAY_CAMPID_DE=
NEXT_PUBLIC_EBAY_CAMPID_FR=
NEXT_PUBLIC_EBAY_CAMPID_IT=
NEXT_PUBLIC_EBAY_CAMPID_ES=

# [optional] GA4 Measurement ID. Currently hard-coded in src/app/layout.tsx;
# this entry is documented for the future env-driven migration.
NEXT_PUBLIC_GA4_MEASUREMENT_ID=

# [optional] Canonical site origin. Falls back to https://www.pokeprices.io.
NEXT_PUBLIC_SITE_URL=

# [optional] Legacy UI-only password for /admin/content-studio.
# Holds no security authority after Block 1A.
NEXT_PUBLIC_ADMIN_PASSWORD=

# [optional] Override for the Supabase Edge Function slug behind the
# Content Studio "Generate" button.
NEXT_PUBLIC_CONTENT_STUDIO_FN_SLUG=


# ── Server-only ─────────────────────────────────────────────────────────────

# [optional] Alternative Supabase base URL used by some edge functions.
# The Next.js app uses NEXT_PUBLIC_SUPABASE_URL instead.
SUPABASE_URL=

# [REQUIRED] Service-role JWT. Required by /api/vendors/submit,
# /api/vendor-logo-upload, /api/unsubscribe, /api/admin/content-studio/posts.
# Production outage if missing.
SUPABASE_SERVICE_ROLE_KEY=

# [optional] Comma-separated lower-case emails authorised to mutate via
# /api/admin/content-studio/posts. Empty → admin mutations refused with 503.
ADMIN_ALLOWED_EMAILS=

# [optional] Shared password gating /intel/* via middleware. Defaults to
# the literal "pokeprices" if absent — set this in production.
INTEL_PASSWORD=

# [optional] Salt mixed into the SHA-256 IP hash stored on
# vendor_upload_tokens.created_ip_hash. Forensics only.
VENDOR_DAILY_IP_SALT=

# [optional] Bearer secret accepted by the evaluate-alerts edge function.
# Set on the cron caller, not the web app.
ALERTS_TRIGGER_SECRET=

# [optional, server-only] Single recipient address used by the temporary
# /api/admin/test-resend smoke-test route. The route never accepts a
# recipient from the browser — only this value is ever sent to. Leave
# unset on environments where the smoke test should be disabled (the
# route will return 503).
EMAIL_TEST_RECIPIENT=


# ── Server-only (Supabase Edge Functions, not the Next app) ────────────────
# Documented for completeness. Configured in Supabase → Functions → Secrets,
# not in Vercel.

# CLAUDE_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_VISION_API_KEY=
# RESEND_API_KEY=


# ── Verifier scripts (development only) ────────────────────────────────────
# Used by scripts/verify-security.mjs and scripts/verify-vendor-security.mjs.
# Required for the scripts to run; never set on production.

VERIFY_ALLOW_NON_PRODUCTION=
TEST_USER_A_EMAIL=
TEST_USER_A_PASSWORD=
TEST_USER_B_EMAIL=
TEST_USER_B_PASSWORD=
NEXT_BASE_URL=
