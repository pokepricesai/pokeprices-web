# PokePrices — environment variable names (Block 1A)
# ----------------------------------------------------
# Names only. NEVER commit real values.

# Supabase (already in use)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Admin authorisation (Block 1A, new)
# Comma-separated, lower-case emails authorised to mutate social_content_posts
# via /api/admin/content-studio/posts. Server-only — never read in the browser.
ADMIN_ALLOWED_EMAILS=

# eBay affiliate (already in use)
NEXT_PUBLIC_EBAY_CAMPID_UK=
NEXT_PUBLIC_EBAY_CAMPID_US=

# Intel (already in use, dev convenience)
INTEL_PASSWORD=
# Legacy UI-only password for the Content Studio. Block 1A demoted this from
# a security gate to a UI convenience. Mutations now require Supabase Auth.
NEXT_PUBLIC_ADMIN_PASSWORD=
# Optional override for the content-studio-generate edge function slug.
NEXT_PUBLIC_CONTENT_STUDIO_FN_SLUG=

# Edge function secrets (set in Supabase, not Vercel)
# CLAUDE_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_VISION_API_KEY=
# RESEND_API_KEY=
# ALERTS_TRIGGER_SECRET=

# Security verifier (scripts/verify-security.mjs)
# Required for the script to run; never set on production.
VERIFY_ALLOW_NON_PRODUCTION=
# Test accounts must be provisioned in a dev/staging Supabase project.
TEST_USER_A_EMAIL=
TEST_USER_A_PASSWORD=
TEST_USER_B_EMAIL=
TEST_USER_B_PASSWORD=
# Optional — if set, the verifier also pings the admin route directly.
NEXT_BASE_URL=
