# PokePrices — environment variable names
# ----------------------------------------
# Names and explanatory comments only. NEVER commit real values.
#
# Scopes
#   * NEXT_PUBLIC_* vars are inlined into the browser bundle at build
#     time. Treat their values as effectively public.
#   * Everything else is server-only. Never read on the client.
#
# Required vs optional
#   * Required vars (marked [REQUIRED]) must be set in Production AND in
#     any Preview environment you expect to use. Missing them in Production
#     produces 500s on routes that depend on them.
#   * Optional vars have a sensible documented fallback in src/lib/env.ts.

# ── Public ──────────────────────────────────────────────────────────────────

# [REQUIRED] Supabase REST + Auth + Storage base URL.
NEXT_PUBLIC_SUPABASE_URL=

# [REQUIRED] Supabase anon JWT for public reads and Auth flows.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# [optional] eBay Partner Network campaign IDs, one per marketplace.
# UK + US ship implemented + configured today.
#
# Important: NEXT_PUBLIC_* values are inlined into the browser bundle
# at BUILD TIME. Setting one in Vercel without triggering a new
# deployment changes nothing on the live site. Populating one of the
# additional CA/AU/DE/FR/IT/ES vars also does NOT activate that
# marketplace by itself — the URL engine in src/lib/ebayAffiliate.ts
# must also be extended and IMPLEMENTED_MARKETPLACES updated.
# Until both sides are true, the marketplace stays hidden from the
# selector and the settings dropdown.
# Missing → affiliate links for that marketplace render with empty
# campid (commission attribution lost) or the marketplace is hidden in
# the selector if it has no campid at all.
NEXT_PUBLIC_EBAY_CAMPID_UK=
NEXT_PUBLIC_EBAY_CAMPID_US=
NEXT_PUBLIC_EBAY_CAMPID_CA=
NEXT_PUBLIC_EBAY_CAMPID_AU=
NEXT_PUBLIC_EBAY_CAMPID_DE=
NEXT_PUBLIC_EBAY_CAMPID_FR=
NEXT_PUBLIC_EBAY_CAMPID_IT=
NEXT_PUBLIC_EBAY_CAMPID_ES=

# [optional] GA4 Measurement ID. Currently hard-coded in src/app/layout.tsx;
# this entry is documented for the future env-driven migration.
NEXT_PUBLIC_GA4_MEASUREMENT_ID=

# [optional] Canonical site origin. Falls back to https://www.pokeprices.io.
NEXT_PUBLIC_SITE_URL=

# [optional] Legacy UI-only password for /admin/content-studio.
# Holds no security authority after Block 1A.
NEXT_PUBLIC_ADMIN_PASSWORD=

# [optional] Override for the Supabase Edge Function slug behind the
# Content Studio "Generate" button.
NEXT_PUBLIC_CONTENT_STUDIO_FN_SLUG=


# ── Server-only ─────────────────────────────────────────────────────────────

# [optional] Alternative Supabase base URL used by some edge functions.
# The Next.js app uses NEXT_PUBLIC_SUPABASE_URL instead.
SUPABASE_URL=

# [REQUIRED] Service-role JWT. Required by /api/vendors/submit,
# /api/vendor-logo-upload, /api/unsubscribe, /api/admin/content-studio/posts.
# Production outage if missing.
SUPABASE_SERVICE_ROLE_KEY=

# [optional] Comma-separated lower-case emails authorised to mutate via
# /api/admin/content-studio/posts. Empty → admin mutations refused with 503.
ADMIN_ALLOWED_EMAILS=

# [optional] Shared password gating /intel/* via middleware. Defaults to
# the literal "pokeprices" if absent — set this in production.
INTEL_PASSWORD=

# [optional] Salt mixed into the SHA-256 IP hash stored on
# vendor_upload_tokens.created_ip_hash. Forensics only.
VENDOR_DAILY_IP_SALT=

# [optional] Bearer secret accepted by the evaluate-alerts edge function.
# Set on the cron caller, not the web app.
ALERTS_TRIGGER_SECRET=

# [optional, server-only] Single recipient address used by the
# admin smoke-test routes (/api/admin/test-resend, /api/admin/email-send-test)
# AND enforced by the central send service on Preview/development
# environments. Leave unset to disable the admin smoke tests (503).
EMAIL_TEST_RECIPIENT=

# [optional, server-only] Override for the From header. Default:
# "PokePrices <hello@pokeprices.io>". Must be a verified Resend sender.
EMAIL_FROM_ADDRESS=

# [optional, server-only] Reply-To header. Default: hello@pokeprices.io
EMAIL_REPLY_TO=

# [optional, server-only] On Preview/development, when set to the
# literal "true", the central send service is allowed to deliver to
# any recipient (not just EMAIL_TEST_RECIPIENT). Leave unset on Vercel
# Preview deployments to keep them safe.
EMAIL_ALLOW_PREVIEW_SEND=

# [optional, server-only] Svix signing secret for the Resend webhook
# receiver. Configure in Resend dashboard → Webhooks → Signing secret
# and paste here. Missing → /api/webhooks/resend returns 503.
RESEND_WEBHOOK_SECRET=

# ── Block 3B onboarding sequence ────────────────────────────────────────────
# [optional, server-only] Feature flag for the onboarding email
# sequence. Set to the literal "true" to enable enrolment + sending.
# Default (unset / false) means no new enrolments and the processor
# returns { processed: 0, disabled: true } without sending. Admin
# preview + test-send routes remain available regardless.
EMAIL_ONBOARDING_ENABLED=

# [REQUIRED for enrolment, server-only] ISO-8601 timestamp. Only
# users whose auth.users.created_at is >= this value can be enrolled.
# Block 3B correction-pass eligibility safeguard against silently
# enrolling existing users on their next login.
# MISSING or INVALID values FAIL CLOSED — no enrolment happens.
# Must be set BEFORE flipping EMAIL_ONBOARDING_ENABLED on. Vercel env
# changes require a fresh deployment.
ONBOARDING_ELIGIBLE_AFTER=

# [optional, server-only] Seconds after which an in-flight processor
# claim is considered stale and may be stolen by a later processor
# (crash recovery). Default 300 (5 minutes).
ONBOARDING_CLAIM_STALE_SECONDS=

# [Block 3D, server-only] Primary bearer secret used by Vercel Cron
# AND for operator POSTs to the internal processor route. Vercel
# automatically sends "Authorization: Bearer <CRON_SECRET>" when it
# invokes a configured cron route. Generate a fresh random value
# (≥ 32 chars) for production.
CRON_SECRET=

# [DEPRECATED, server-only] Legacy bearer secret. Accepted for one
# release alongside CRON_SECRET so the operator can roll the new
# value out before retiring this one. Remove from Vercel after a
# successful cron invocation — see docs/email-onboarding.md.
ONBOARDING_CRON_SECRET=

# [optional, server-only] Override the default step delays. Defaults:
# welcome 10 min, activation 2 days, discovery 7 days. Operators may
# shrink these for controlled rollout tests.
ONBOARDING_WELCOME_DELAY_MS=
ONBOARDING_ACTIVATION_DELAY_MS=
ONBOARDING_DISCOVERY_DELAY_MS=


# ── Block 4B-W-1 — Recent Sales (server-only feature flags) ────────────────
# All five flags must be set to the literal "true" to take effect.
# Any other state (empty, missing, "1", "yes", "TRUE") leaves the flag
# off. Vercel env changes require a fresh deployment.
# Never expose any of these as NEXT_PUBLIC_*.

# Gates the scraper-side write path into recent_sales. When off,
# absolutely no rows are written.
RECENT_SALES_INGESTION_ENABLED=

# Gates the future admin review surface at /admin/recent-sales.
RECENT_SALES_ADMIN_VIEW_ENABLED=

# Gates the customer-facing Free preview component on card pages
# (built in a later block).
RECENT_SALES_FREE_PREVIEW_ENABLED=

# Gates the locked Pro preview component on card pages (built in a
# later block).
RECENT_SALES_PRO_PREVIEW_ENABLED=

# When set to "true", ingestion ignores the recent_sales_card_allow_list
# and processes the full catalogue. Stage-5 flip.
RECENT_SALES_FULL_CATALOGUE=


# ── Server-only (Supabase Edge Functions, not the Next app) ────────────────
# Documented for completeness. Configured in Supabase → Functions → Secrets,
# not in Vercel.

# CLAUDE_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_VISION_API_KEY=
# RESEND_API_KEY=


# ── Verifier scripts (development only) ────────────────────────────────────
# Used by scripts/verify-security.mjs and scripts/verify-vendor-security.mjs.
# Required for the scripts to run; never set on production.

VERIFY_ALLOW_NON_PRODUCTION=
TEST_USER_A_EMAIL=
TEST_USER_A_PASSWORD=
TEST_USER_B_EMAIL=
TEST_USER_B_PASSWORD=
NEXT_BASE_URL=
